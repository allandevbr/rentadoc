<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Análise Rentabilidade — Documentação</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:         #f7f6f3;
    --surface:    #ffffff;
    --border:     #e8e4dd;
    --text-main:  #1a1814;
    --text-muted: #7a7468;
    --text-light: #b0aa9f;
    --green:      #1e7a4a;
    --green-bg:   #edf7f2;
    --red:        #b93030;
    --red-bg:     #fdf0f0;
    --amber:      #92600a;
    --amber-bg:   #fdf6e8;
    --blue:       #1a4fa0;
    --blue-bg:    #eff4fc;
    --accent:     #2d5a3d;
    --code-bg:    #f0ede8;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text-main);
    line-height: 1.7;
    font-size: 15px;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 260px;
    height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    z-index: 100;
    display: flex;
    flex-direction: column;
  }

  .sidebar-header {
    padding: 28px 24px 20px;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-logo {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 4px;
  }

  .sidebar-title {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .sidebar-nav { padding: 16px 0; flex: 1; }

  .nav-section {
    padding: 8px 24px 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 24px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.15s;
    border-left: 2px solid transparent;
    font-weight: 400;
  }

  .nav-link:hover {
    color: var(--text-main);
    background: var(--bg);
    border-left-color: var(--accent);
  }

  .nav-link .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .nav-link .col-label {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    color: var(--text-light);
    margin-left: auto;
  }

  /* ── MAIN ── */
  .main {
    margin-left: 260px;
    min-height: 100vh;
  }

  /* ── HERO ── */
  .hero {
    background: var(--accent);
    padding: 72px 64px 56px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -80px; left: 30%;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(255,255,255,0.03);
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.65);
    max-width: 520px;
    line-height: 1.6;
    font-weight: 300;
    position: relative;
    z-index: 1;
  }

  .hero-meta {
    display: flex;
    gap: 32px;
    margin-top: 40px;
    position: relative;
    z-index: 1;
  }

  .hero-meta-item { }

  .hero-meta-value {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: #fff;
    font-weight: 600;
  }

  .hero-meta-label {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* ── INTRO CARD ── */
  .intro-section {
    padding: 48px 64px;
    border-bottom: 1px solid var(--border);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
  }

  .intro-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
  }

  .intro-card-icon {
    font-size: 24px;
    margin-bottom: 12px;
  }

  .intro-card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 6px;
  }

  .intro-card-text {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── SECTION ── */
  .content { padding: 48px 64px 96px; }

  .section-group {
    margin-bottom: 64px;
  }

  .section-group-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .section-group-number {
    font-family: 'Playfair Display', serif;
    font-size: 13px;
    color: var(--text-light);
    font-weight: 400;
    flex-shrink: 0;
  }

  .section-group-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--text-main);
  }

  .section-group-tag {
    margin-left: auto;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    flex-shrink: 0;
  }

  .tag-volume   { background: var(--blue-bg);  color: var(--blue);  }
  .tag-cost     { background: var(--amber-bg); color: var(--amber); }
  .tag-margin   { background: var(--green-bg); color: var(--green); }
  .tag-result   { background: #f3f0ff;         color: #5b3fa8;      }
  .tag-deduct   { background: var(--red-bg);   color: var(--red);   }

  /* ── METRIC CARD ── */
  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 16px;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .metric-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .metric-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    cursor: pointer;
  }

  .metric-col-badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: var(--text-light);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 8px;
    white-space: nowrap;
  }

  .metric-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
  }

  .metric-formula-pill {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    background: var(--code-bg);
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .metric-body {
    padding: 0 24px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    border-top: 1px solid var(--border);
    padding-top: 20px;
  }

  .metric-body.full { grid-template-columns: 1fr; }

  .metric-what-title,
  .metric-tip-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 8px;
  }

  .metric-what-text,
  .metric-tip-text {
    font-size: 13.5px;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .metric-tip-box {
    background: var(--bg);
    border-radius: 8px;
    padding: 14px 16px;
    border-left: 3px solid var(--border);
  }

  .metric-tip-box.green  { background: var(--green-bg); border-left-color: var(--green); }
  .metric-tip-box.red    { background: var(--red-bg);   border-left-color: var(--red);   }
  .metric-tip-box.amber  { background: var(--amber-bg); border-left-color: var(--amber); }
  .metric-tip-box.blue   { background: var(--blue-bg);  border-left-color: var(--blue);  }

  /* ── CODE BLOCK ── */
  .code-section {
    margin-top: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .code-section-header {
    padding: 10px 16px;
    background: var(--code-bg);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .code-section-title {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .code-block {
    padding: 20px 24px;
    overflow-x: auto;
  }

  .code-block pre {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    line-height: 1.8;
    color: var(--text-main);
    white-space: pre;
  }

  .code-comment { color: var(--text-light); }
  .code-keyword { color: #1a4fa0; font-weight: 500; }
  .code-string  { color: #1e7a4a; }
  .code-func    { color: #92600a; }
  .code-measure { color: #5b3fa8; }

  /* ── EXAMPLE ROW ── */
  .example-row {
    display: flex;
    gap: 12px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .example-pill {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 13px;
  }

  .example-pill strong {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: var(--text-main);
    font-family: 'DM Mono', monospace;
  }

  .example-pill span {
    font-size: 11px;
    color: var(--text-muted);
  }

  /* ── SCALE GUIDE ── */
  .scale-guide {
    display: flex;
    gap: 8px;
    margin-top: 16px;
    flex-wrap: wrap;
  }

  .scale-item {
    border-radius: 6px;
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 500;
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 40px 64px;
    margin-left: 260px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-brand {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--accent);
  }

  .footer-note {
    font-size: 12px;
    color: var(--text-light);
  }

  /* ── DIVIDER ── */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 40px 0;
  }

  /* ── SECTION TITLE ── */
  .section-title-main {
    font-family: 'Playfair Display', serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 8px;
  }

  .section-desc {
    font-size: 14px;
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.6;
  }

  /* ── SCROLLBAR ── */
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  @media (max-width: 900px) {
    .sidebar { display: none; }
    .main, .footer { margin-left: 0; }
    .hero, .intro-section, .content { padding: 32px 24px; }
    .intro-grid { grid-template-columns: 1fr; }
    .metric-body { grid-template-columns: 1fr; }
    .hero-title { font-size: 32px; }
    .footer { padding: 32px 24px; }
  }
</style>
</head>
<body>

